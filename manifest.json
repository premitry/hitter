{
  "manifest_version": 3,
  "name": "Form Autofill Helper",
  "version": "1.0.0",
  "description": "Fills name and address fields on the active tab using a user-provided email and locale.",
  "icons": {
    "16": "icons/icon16.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Form Autofill"
  },
  "permissions": ["activeTab", "scripting", "storage"]
}
